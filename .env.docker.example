

APP_NAME=Mosure
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_TIMEZONE=Asia/Shanghai
APP_URL=http://localhost:9445

APP_LOCALE=cn
APP_FALLBACK_LOCALE=cn
APP_FAKER_LOCALE=cn

APP_MAINTENANCE_DRIVER=file

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=info
SQL_LOG_ENABLED=false
SQL_LOG_FULL=false
SQL_LOG_SLOW_MS=500
SQL_LOG_BINDINGS=false

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=mosure
DB_USERNAME=mosure
DB_PASSWORD=secret

CACHE_STORE=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
FILESYSTEM_DISK=public

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log

RUN_MIGRATIONS=true

VITE_APP_NAME="${APP_NAME}"

# Plugin marketplace (disabled by default; configure explicitly when needed)
PLUGIN_MARKETPLACE_ENABLED=false
PLUGIN_MARKETPLACE_TYPE=gitee
GITEE_REPO_OWNER=
GITEE_REPO_NAME=
GITEE_REPO_BRANCH=master
GITEE_ACCESS_TOKEN=
