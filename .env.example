APP_NAME=Mosure
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Asia/Shanghai
# Written by installer (/api/install/doInstall)
APP_URL=

APP_LOCALE=cn
APP_FALLBACK_LOCALE=cn
APP_FAKER_LOCALE=cn

APP_MAINTENANCE_DRIVER=file

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug
SQL_LOG_ENABLED=false
SQL_LOG_FULL=false
SQL_LOG_SLOW_MS=500
SQL_LOG_BINDINGS=false

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=

FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=file
CACHE_PREFIX=

MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_PORT=2525

# Plugin marketplace (disabled by default; configure explicitly when needed)
PLUGIN_MARKETPLACE_ENABLED=false
PLUGIN_MARKETPLACE_TYPE=gitee
GITEE_REPO_OWNER=
GITEE_REPO_NAME=
GITEE_REPO_BRANCH=master
GITEE_ACCESS_TOKEN=
