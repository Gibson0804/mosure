APP_NAME=Mosure
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Asia/Shanghai
APP_URL=http://localhost:9445

APP_LOCALE=cn
APP_FALLBACK_LOCALE=cn
APP_FAKER_LOCALE=cn

APP_MAINTENANCE_DRIVER=file

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug
SQL_LOG_ENABLED=true
SQL_LOG_FULL=true
SQL_LOG_SLOW_MS=500
SQL_LOG_BINDINGS=false

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=file
CACHE_PREFIX=

VITE_APP_NAME="${APP_NAME}"

APP_URL=http://127.0.0.1:9445
DB_CONNECTION=sqlite
DB_DATABASE=
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=

MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_PORT=2525

# Plugin marketplace (disabled by default; configure explicitly when needed)
PLUGIN_MARKETPLACE_ENABLED=false
PLUGIN_MARKETPLACE_TYPE=gitee
GITEE_REPO_OWNER=
GITEE_REPO_NAME=
GITEE_REPO_BRANCH=master
GITEE_ACCESS_TOKEN=
